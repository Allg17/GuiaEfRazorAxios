@using GuiaEfRazorAxios
@using GuiaEfRazorAxios.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@*
    Archivo: Views/_ViewImports.cshtml
    Objetivo: importar namespaces y activar Tag Helpers para todas las vistas Razor.
    @using evita repetir namespaces en cada vista.
    @addTagHelper habilita atributos como asp-controller, asp-action, asp-for y asp-validation-for.
    Tag Helpers: https://learn.microsoft.com/en-us/aspnet/core/mvc/views/tag-helpers/intro
*@
