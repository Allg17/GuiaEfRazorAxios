 @{
    ViewData["Title"] = "Productos con Axios";
}

@*
    Vista: Views/ProductosAxios/Index.cshtml
    Ruta MVC: /ProductosAxios
    Controlador/accion: ProductosAxiosController.Index()
    Objetivo: mostrar una vista MVC que consume una API JSON con JavaScript y Axios.
    Diferencia con Razor tradicional: el HTML inicial llega desde MVC, pero los datos se cargan despues con axios.get().
    Endpoints usados: GET /api/productos, GET /api/productos/categorias y POST /api/productos.
    Conceptos usados: @section Scripts, DOM, async/await, axios.get, axios.post, JSON y API Controller.
    Axios: https://axios-http.com/docs/intro
    API/MVC: https://learn.microsoft.com/en-us/aspnet/core/mvc/overview
*@
@* d-flex, justify-content-between y align-items-center son clases de Bootstrap para ordenar el encabezado en una fila flexible. *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3">Productos con Axios</h1>
        <p class="text-muted mb-0">Vista MVC que consume una API JSON desde JavaScript.</p>
    </div>
    @* asp-controller y asp-action son Tag Helpers: generan el href correcto hacia HomeController.Index(). *@
    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Volver</a>
</div>

@* El div empieza oculto con d-none. JavaScript cambia sus clases para mostrar mensajes de exito o error. *@
<div id="mensaje" class="alert d-none" role="alert"></div>

@* row y col-lg-* crean una grilla Bootstrap: formulario a la izquierda y tabla a la derecha en pantallas grandes. *@
<section class="row g-4">
    <div class="col-lg-5">
        @* id="productoForm" permite encontrar el formulario desde JavaScript con document.querySelector. *@
        <form id="productoForm" class="border rounded p-3">
            <h2 class="h5">Crear producto por API</h2>

            <div class="mb-3">
                <label for="nombre" class="form-label">Nombre</label>
                @* required y maxlength validan en el navegador antes de enviar la solicitud con Axios. *@
                <input id="nombre" class="form-control" maxlength="100" required>
            </div>

            <div class="mb-3">
                <label for="categoriaId" class="form-label">Categoria</label>
                @* El select inicia vacio porque JavaScript lo llena con datos de GET /api/productos/categorias. *@
                <select id="categoriaId" class="form-select" required></select>
            </div>

            <div class="mb-3">
                <label for="precio" class="form-label">Precio</label>
                @* type="number" muestra controles numericos; min y step ayudan a capturar decimales validos. *@
                <input id="precio" class="form-control" type="number" min="0.01" step="0.01" required>
            </div>

            <div class="mb-3">
                <label for="stock" class="form-label">Stock</label>
                @* step="1" indica que el stock debe avanzar de uno en uno porque es una cantidad entera. *@
                <input id="stock" class="form-control" type="number" min="0" step="1" required>
            </div>

            <button class="btn btn-primary" type="submit">Guardar con Axios</button>
        </form>
    </div>

    <div class="col-lg-7">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Categoria</th>
                    <th>Precio</th>
                    <th>Stock</th>
                </tr>
            </thead>
            @* tbody empieza vacio porque JavaScript insertara filas <tr> despues de llamar GET /api/productos. *@
            <tbody id="productosBody"></tbody>
        </table>
    </div>
</section>

@section Scripts {
    @*
        @section Scripts envia estos scripts al lugar donde _Layout.cshtml ejecuta RenderSectionAsync("Scripts").
        Esto permite cargar JavaScript al final del body, cuando el HTML ya existe en el DOM.
    *@
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        // document.querySelector busca un elemento del HTML usando un selector CSS.
        // Guardar estas referencias evita repetir busquedas cada vez que se actualiza la pantalla.
        const productosBody = document.querySelector("#productosBody");
        const categoriaSelect = document.querySelector("#categoriaId");
        const mensaje = document.querySelector("#mensaje");
        const form = document.querySelector("#productoForm");

        // Muestra mensajes de exito o error reutilizando estilos de Bootstrap.
        // className reemplaza todas las clases del div mensaje.
        // Ejemplo: alert alert-success muestra verde; alert alert-danger muestra rojo.
        function mostrarMensaje(texto, tipo = "success") {
            mensaje.textContent = texto;
            mensaje.className = `alert alert-${tipo}`;
        }

        // Carga categorias desde la API para llenar el select.
        async function cargarCategorias() {
            // axios.get hace una solicitud HTTP GET y devuelve una promesa.
            // await espera la respuesta antes de continuar.
            const respuesta = await axios.get("/api/productos/categorias");

            // Limpia opciones anteriores para evitar duplicados si se vuelve a llamar la funcion.
            categoriaSelect.innerHTML = "";

            // respuesta.data contiene el JSON devuelto por ApiProductosController.GetCategorias().
            for (const categoria of respuesta.data) {
                // document.createElement crea un nodo HTML <option> desde JavaScript.
                const option = document.createElement("option");

                // value es el dato que se enviara como CategoriaId cuando el usuario seleccione la opcion.
                option.value = categoria.id;

                // textContent es el texto visible del option.
                option.textContent = categoria.nombre;

                // appendChild agrega el option dentro del select.
                categoriaSelect.appendChild(option);
            }
        }

        // Carga productos desde la API y pinta cada producto en una fila de tabla.
        async function cargarProductos() {
            // Llama al endpoint que devuelve productos ya transformados a ProductoListDto.
            const respuesta = await axios.get("/api/productos");

            // Limpia la tabla antes de volver a dibujarla para que no se dupliquen filas.
            productosBody.innerHTML = "";

            for (const producto of respuesta.data) {
                // Crea una fila <tr> por cada producto recibido.
                const row = document.createElement("tr");

                // innerHTML inserta celdas HTML dentro de la fila.
                // En proyectos reales con datos no confiables se debe evitar inyectar HTML sin sanitizar.
                row.innerHTML = `
                    <td>${producto.nombre}</td>
                    <td>${producto.categoria}</td>
                    <td>${Number(producto.precio).toFixed(2)}</td>
                    <td>${producto.stock}</td>
                `;

                // Agrega la fila completa al cuerpo de la tabla.
                productosBody.appendChild(row);
            }
        }

        // Intercepta el envio del formulario para mandar JSON con Axios.
        form.addEventListener("submit", async (event) => {
            // preventDefault evita el comportamiento normal del formulario.
            // Sin esto, el navegador recargaria la pagina y enviaria un POST tradicional.
            // Como aqui queremos enviar JSON con Axios, se cancela ese envio automatico.
            event.preventDefault();

            // Crea un objeto JavaScript con la misma forma que ProductoCreateDto en C#.
            // Los nombres deben coincidir para que ASP.NET Core pueda enlazar el JSON al DTO.
            const producto = {
                nombre: document.querySelector("#nombre").value,

                // Number convierte el value del select, que llega como texto, a numero.
                // CategoriaId en C# es int, por eso conviene enviarlo como numero.
                categoriaId: Number(categoriaSelect.value),

                // El valor de un input tambien llega como texto; Number lo transforma a numero.
                precio: Number(document.querySelector("#precio").value),
                stock: Number(document.querySelector("#stock").value)
            };

            try {
                // axios.post envia el objeto producto como JSON al endpoint POST /api/productos.
                // await espera a que la API responda antes de limpiar formulario o recargar tabla.
                await axios.post("/api/productos", producto);

                // form.reset() limpia los campos del formulario y los devuelve a su valor inicial.
                // Se usa solo despues de guardar correctamente para que el usuario vea que la operacion termino.
                // No borra la tabla ni la base de datos; solo reinicia los controles HTML del formulario.
                form.reset();

                // Vuelve a consultar productos para mostrar en la tabla el registro recien creado.
                await cargarProductos();

                // Muestra confirmacion visual al usuario.
                mostrarMensaje("Producto guardado correctamente desde la API.");
            } catch (error) {
                // catch captura errores de red, errores HTTP o validaciones rechazadas por la API.
                mostrarMensaje("No se pudo guardar. Revisa los datos enviados.", "danger");

                // console.error deja el detalle tecnico en la consola del navegador para depuracion.
                console.error(error);
            }
        });

        // Punto de entrada de la vista: carga datos apenas la pagina termina de renderizar.
        async function iniciarPagina() {
            try {
                // Primero carga categorias para que el select tenga opciones.
                await cargarCategorias();

                // Despues carga productos para llenar la tabla inicial.
                await cargarProductos();
            } catch (error) {
                // Si falla la carga inicial, se informa al usuario y se registra el detalle tecnico.
                mostrarMensaje("No se pudo cargar la informacion desde la API.", "danger");
                console.error(error);
            }
        }

        // Ejecuta la funcion inicial. Sin esta llamada, el select y la tabla quedarian vacios.
        iniciarPagina();
    </script>
}
