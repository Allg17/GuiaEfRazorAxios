<!DOCTYPE html>
<html lang="en">
<head>
    @*
        Vista compartida: Views/Shared/_Layout.cshtml
        Objetivo: definir la estructura HTML comun para todas las vistas.
        Contiene head, CSS, navbar, contenedor principal, footer y scripts base.
        RenderBody() indica donde se inserta el contenido de cada vista hija.
        RenderSectionAsync("Scripts") permite que una vista agregue scripts propios al final.
        Layouts: https://learn.microsoft.com/en-us/aspnet/core/mvc/views/layout
    *@
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GuiaEfRazorAxios</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GuiaEfRazorAxios.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GuiaEfRazorAxios</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Categorias" asp-action="Index">Categorias</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Productos" asp-action="Index">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="ProductosAxios" asp-action="Index">HTML + Axios</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @* RenderBody inserta aqui el HTML especifico de la vista actual, por ejemplo Categorias/Index o Productos/Create. *@
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GuiaEfRazorAxios - Proyecto educativo ASP.NET Core
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* RenderSectionAsync imprime scripts opcionales definidos por una vista con @section Scripts. required:false significa que no todas las vistas estan obligadas a tener esa seccion. *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
