@model IEnumerable<GuiaEfRazorAxios.Models.Categoria>

@*
    Vista: Views/Categorias/Index.cshtml
    Ruta MVC: /Categorias
    Controlador/accion: CategoriasController.Index()
    Modelo recibido: IEnumerable<Categoria>, una lista de categorias enviada por CategoriaService.
    Objetivo: mostrar categorias y el conteo de productos relacionados en la relacion uno-a-muchos.
    Conceptos usados: Razor Views, @model, foreach, Tag Helpers asp-action y asp-route-id.
    Documentacion: https://learn.microsoft.com/en-us/aspnet/core/mvc/views/overview
*@

@{
    ViewData["Title"] = "Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3">Categorias</h1>
        <p class="text-muted mb-0">Tabla principal de la relacion uno-a-muchos.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Nueva categoria</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripcion</th>
            <th>Productos relacionados</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var categoria in Model)
    {
        <tr>
            <td>@categoria.Nombre</td>
            <td>@categoria.Descripcion</td>
            <td>@categoria.Productos.Count</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@categoria.Id">Ver</a>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@categoria.Id">Editar</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@categoria.Id">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>
